rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function rosterDoc(appId, uid) {
      return /databases/$(database)/documents/artifacts/$(appId)/public/data/roster/$(uid);
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin(appId) {
      return signedIn()
        && exists(rosterDoc(appId, request.auth.uid))
        && get(rosterDoc(appId, request.auth.uid)).data.role == 'admin';
    }

    function validPendingRosterCreate(uid) {
      return request.resource.data.uid == uid
        && request.resource.data.role == 'staff'
        && request.resource.data.status == 'pending';
    }

    match /artifacts/{appId} {
      match /public/data/inventory/master {
        allow read: if signedIn();
        allow write: if isAdmin(appId);
      }

      match /public/data/roster/{uid} {
        allow read: if signedIn();
        allow create: if isAdmin(appId) || (isSelf(uid) && validPendingRosterCreate(uid));
        allow update, delete: if isAdmin(appId);
      }

      match /public/data/requests/{requestId} {
        allow read: if isAdmin(appId);
        allow create: if signedIn()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.status == 'pending';
        allow update, delete: if isAdmin(appId);
      }

      match /public/data/alerts/{alertId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.target is string
          && request.resource.data.message is string
          && request.resource.data.timestamp is number;
        allow update, delete: if false;
      }

      match /public/data/messages/{messageId} {
        allow read: if isAdmin(appId)
          || (signedIn()
            && request.auth.uid in resource.data.participants);
        allow create: if signedIn()
          && request.resource.data.fromUid == request.auth.uid
          && request.resource.data.participants is list
          && request.auth.uid in request.resource.data.participants;
        allow update, delete: if isAdmin(appId);
      }

      match /users/{uid}/data/app_state {
        allow read: if isSelf(uid) || isAdmin(appId);
        allow create, update: if isSelf(uid) || isAdmin(appId);
        allow delete: if isAdmin(appId);
      }

      match /users/{uid}/settings/{docId} {
        allow read: if isSelf(uid) || isAdmin(appId);
        allow create, update: if isSelf(uid) || isAdmin(appId);
        allow delete: if isAdmin(appId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
