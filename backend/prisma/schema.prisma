generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  WORKER
}

enum ProductType {
  HARD
  SOFT
}

enum CommissionType {
  PERCENTAGE
  FLAT
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  googleSub    String   @unique
  role         Role
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  sales        Sale[]
  adjustments  InventoryAdjustment[]
}

model Product {
  id              String   @id @default(cuid())
  name            String
  type            ProductType
  totalQuantity   Decimal  @db.Decimal(12, 1)
  costPrice       Decimal  @db.Decimal(12, 2)
  sellPrice       Decimal  @db.Decimal(12, 2)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  sales           Sale[]
  adjustments     InventoryAdjustment[]

  @@unique([name, type])
}

model Sale {
  id                 String   @id @default(cuid())
  userId             String
  productId          String
  type               ProductType
  quantitySold       Decimal  @db.Decimal(12, 1)
  unitCostPrice      Decimal  @db.Decimal(12, 2)
  unitSellPrice      Decimal  @db.Decimal(12, 2)
  expectedTotal      Decimal  @db.Decimal(12, 2)
  amountReceived     Decimal  @db.Decimal(12, 2)
  cuffed             Boolean  @default(false)
  unpaidBalance      Decimal  @db.Decimal(12, 2)
  isPersonalUse      Boolean  @default(false)
  commissionType     CommissionType?
  commissionValue    Decimal? @db.Decimal(12, 2)
  commissionAmount   Decimal? @db.Decimal(12, 2)
  latitude           Decimal? @db.Decimal(10, 7)
  longitude          Decimal? @db.Decimal(10, 7)
  createdAt          DateTime @default(now())

  user               User     @relation(fields: [userId], references: [id])
  product            Product  @relation(fields: [productId], references: [id])
}

model Settings {
  id                        Int            @id @default(1)
  cuffEnabled               Boolean        @default(true)
  personalUseMultiplier     Decimal        @db.Decimal(6, 4) @default(0.1000)
  commissionType            CommissionType @default(PERCENTAGE)
  commissionValue           Decimal        @db.Decimal(12, 2) @default(0)
  updatedAt                 DateTime       @updatedAt
}

model InventoryAdjustment {
  id             String   @id @default(cuid())
  productId      String
  adjustedById   String
  previousQty    Decimal  @db.Decimal(12, 1)
  newQty         Decimal  @db.Decimal(12, 1)
  reason         String
  createdAt      DateTime @default(now())

  product        Product  @relation(fields: [productId], references: [id])
  adjustedBy     User     @relation(fields: [adjustedById], references: [id])
}
